# Shared
APP_ENV=local
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=

# Postgres (docker compose defaults)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/appdb

# Security
JWT_ISSUER=job-app-assistant
JWT_AUDIENCE=job-app-assistant-web
JWT_SECRET=dev-only-change-me

# AI (stubbed; wire your provider)
AI_PROVIDER=stub
AI_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Security / encryption (optional but recommended)
FERNET_SECRET=

# Observability (optional)
SENTRY_DSN=
SENTRY_ENV=local

# Admin (beta)
ADMIN_EMAILS=

# Beta access control
# When true, /api/auth/signup requires a valid beta invite code for the email.
BETA_INVITE_ONLY=false
